# THEME (dank material shell generated colors)
config-file = config-dankcolors

font-family = CaskaydiaCove Nerd Font Mono
font-size = 12
window-decoration = false
gtk-tabs-location = hidden

background-blur = true

window-padding-x = 10
window-padding-y = 10

cursor-style = bar
cursor-style-blink = false

# KEYBINDS

# copy/paste
keybind = ctrl+alt+c=copy_to_clipboard
keybind = ctrl+alt+v=paste_from_clipboard

# closing things
keybind = ctrl+alt+q=close_surface

# fullscreen
keybind = ctrl+alt+f=toggle_fullscreen

# terminal
command = /usr/bin/fish --login --interactive
